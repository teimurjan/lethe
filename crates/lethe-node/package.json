{
  "name": "@lethe-memory/lethe",
  "version": "0.10.0",
  "description": "Node bindings to the lethe memory store (Rust core via napi-rs).",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": "github:teimurjan/lethe",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "name": "@lethe-memory/lethe",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "napi build --platform --release && node test/smoke.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  }
}
